@{
    var student = ViewBag.Student as SchoolManagementSystem.Models.Student;
    var majors = ViewBag.Majors as List<SchoolManagementSystem.Models.Major>;
}

<div class="container mt-4">
    <h2>Assign Major for @student.FullNames</h2>
    <hr />

    <form asp-action="AssignMajor" method="post">
        <input type="hidden" name="studentId" value="@student.StudentId" />

        <div class="mb-3">
            <label class="form-label">Select Major</label>
            <select name="majorId" class="form-select" required>
                <option value="">-- Select Major --</option>
                @foreach (var major in majors)
                {
                    <option value="@major.MajorId">@major.MajorName</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Math Track</label>
            <input type="text" name="mathTrack" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Science Track</label>
            <input type="text" name="scienceTrack" class="form-control" required />
        </div>

        <button class="btn btn-primary">Save</button>
    </form>
</div>