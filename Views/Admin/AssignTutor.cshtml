@{
    ViewBag.Title = "Assign Tutor";
    var tutors = ViewBag.Tutors as List<SchoolManagementSystem.Models.Tutor>;
    var students = ViewBag.Students as List<SchoolManagementSystem.Models.Student>;
    var subjects = ViewBag.Subjects as List<SchoolManagementSystem.Models.Subject>;
}

<div class="container mt-4">
    <h2>Assign Tutor to Student</h2>
    <hr />

    <form asp-action="AssignTutor" method="post">

        <div class="mb-3">
            <label class="form-label">Select Tutor</label>
            <select name="tutorId" class="form-select" required>
                <option value="">-- Select Tutor --</option>
                @foreach (var t in tutors)
                {
                    <option value="@t.TutorId">@t.FullNames</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Select Student</label>
            <select name="studentId" class="form-select" required>
                <option value="">-- Select Student --</option>
                @foreach (var s in students)
                {
                    <option value="@s.StudentId">@s.FullNames</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Select Subject</label>
            <select name="subjectId" class="form-select" required>
                <option value="">-- Select Subject --</option>
                @foreach (var sub in subjects)
                {
                    <option value="@sub.SubjectId">@sub.SubjectName</option>
                }
            </select>
        </div>

        <button class="btn btn-success">Assign Tutor</button>
    </form>
</div>