@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row g-3">

    <div class="col-md-3">
        <div class="stat-card bg-primary">
            <div class="d-flex justify-content-between">
                <div>
                    <h6>Total Students</h6>
                    <h3>@ViewBag.TotalStudents</h3>
                </div>
                <div class="stat-icon"><i class="fa fa-user-graduate"></i></div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card bg-success">
            <div class="d-flex justify-content-between">
                <div>
                    <h6>Total Teachers</h6>
                    <h3>@ViewBag.TotalTeachers</h3>
                </div>
                <div class="stat-icon"><i class="fa fa-chalkboard-teacher"></i></div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card bg-warning">
            <div class="d-flex justify-content-between">
                <div>
                    <h6>Total Tutors</h6>
                    <h3>@ViewBag.TotalTutors</h3>
                </div>
                <div class="stat-icon"><i class="fa fa-user-tie"></i></div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="stat-card bg-danger">
            <div class="d-flex justify-content-between">
                <div>
                    <h6>Total Subjects</h6>
                    <h3>@ViewBag.TotalSubjects</h3>
                </div>
                <div class="stat-icon"><i class="fa fa-book"></i></div>
            </div>
        </div>
    </div>

</div>

<!-- EXTRA SECTION -->
<div class="card mt-4 p-3 shadow-sm">
    <h5>System Overview</h5>
    <p class="text-muted">
        Welcome to the School Management Admin Panel.
        Use the sidebar to manage students, teachers, tutors, subjects, and reports efficiently.
    </p>
</div>